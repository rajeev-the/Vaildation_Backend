# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/transaction_validator
ALEMBIC_DATABASE_URL=postgresql://user:password@localhost:5432/transaction_validator

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Upload Configuration
MAX_UPLOAD_SIZE_MB=100
CHUNK_ROW_THRESHOLD=10000

# Default Country for Validation
DEFAULT_COUNTRY=US

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# S3 Folder Prefixes
S3_UPLOADS_PREFIX=uploads
S3_OUTPUTS_PREFIX=outputs
S3_CHUNKS_PREFIX=chunks

# Presigned URL Expiration (in seconds, default 3600 = 1 hour)
S3_PRESIGNED_URL_EXPIRATION=3600
